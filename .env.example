# ── ИИ-провайдер ──────────────────────────────────────────────────
# Сейчас: gigachat
# Для теста без токенов GigaChat: anthropic
AI_PROVIDER=gigachat

# GigaChat (основной)
# Как получить: developers.sber.ru/studio → создать проект → GigaChat API
# Credentials = Base64(ClientID:ClientSecret)
GIGACHAT_CREDENTIALS=ВАШ_CREDENTIALS_BASE64
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Anthropic Claude (запасной, для тестирования)
ANTHROPIC_API_KEY=sk-ant-КЛЮЧ_ДЛЯ_ТЕСТА

# ── PostgreSQL ─────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=pss_db
PG_USER=postgres
PG_PASSWORD=ВАШ_ПАРОЛЬ
